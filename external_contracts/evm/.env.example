# Token Bridge Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================

# Owner address - has OWNER_ROLE
# This address controls all administrative functions
OWNER_ADDRESS=0xCcA55A052F2140541b6650093890A0a21405dCc7

# System wallet address - has SYSTEM_WALLET_ROLE  
# This address is authorized to release tokens
SYSTEM_WALLET_ADDRESS=0xCcA55A052F2140541b6650093890A0a21405dCc7

# Fee token address (ERC20)
# Set to zero address (0x0000000000000000000000000000000000000000) if no fee initially
FEE_TOKEN_ADDRESS=0x0d5662c4b6B70433CF32ef3D0c5ccc815A7B17f4

# Fee amount in wei (18 decimals for most tokens)
# Example: 0.1 tokens = 100000000000000000
FEE_AMOUNT=1000000000000000000

# Current chain ID (EIP-155 format)
CURRENT_CHAIN_ID=pruv:testnet

# ===========================================
# POST-DEPLOYMENT CONFIGURATION  
# ===========================================

# Deployed proxy address (set after deployment)
PROXY_ADDRESS=0xBBC3382D647934025aa295811C7E97080c386746
IMPLEMENTATION_ADDRESS=0x01Ef29378213bD8dB80a299Da305CA34E52D9fa6

# Comma-separated list of token addresses to support
# Example: 0x123...,0x456...,0x789...
SUPPORTED_TOKENS=

# Comma-separated list of chain IDs to support
# Example: 1,56,137 (Ethereum, BSC, Polygon)
SUPPORTED_CHAINS=

# ===========================================
# ROLE MANAGEMENT (Optional)
# ===========================================

# Additional addresses to grant PAUSER_ROLE (comma-separated)
ADDITIONAL_PAUSERS=

# Additional addresses to grant UPGRADER_ROLE (comma-separated)
ADDITIONAL_UPGRADERS=

# ===========================================
# PRIVATE KEYS (Keep secure! Never commit!)
# ===========================================

# Admin private key (optional, uses default signer if not set)
PRIVATE_KEY=
SECOND_PRIVATE_KEY=

# Upgrader private key (optional, for upgrade script)
# UPGRADER_PRIVATE_KEY=

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# RPC URLs for different networks (add as needed)
# MAINNET_RPC_URL=
# GOERLI_RPC_URL=
# SEPOLIA_RPC_URL=
# BSC_RPC_URL=
# POLYGON_RPC_URL=

# Block explorer API keys for verification (optional)
# ETHERSCAN_API_KEY=
# BSCSCAN_API_KEY=
# POLYGONSCAN_API_KEY=

