# EVM Network Configuration
# Private key for EVM deployments (without 0x prefix)
PRIVATE_KEY=

# Stellar Network Configuration
# Secret key for Stellar deployments (starts with S)
STELLAR_SECRET_KEY=

# Optional: Default token parameters
# These can be overridden via Makefile arguments
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
ASSET_CODE=MYASSET

