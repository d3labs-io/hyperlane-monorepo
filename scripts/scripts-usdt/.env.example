# Private key of the sender wallet (without 0x prefix is fine, both formats accepted)
PRIVATE_KEY=

# Amount in human-readable format (e.g., 0.1 = 0.1 USDT, 1 = 1 USDT)
TOKEN_AMOUNT=0.1

# Source chain: "kaia" or "pruv"
SOURCE_CHAIN=kaia

# Destination chain: "kaia" or "pruv"
DESTINATION_CHAIN=pruv
